# ── Instagram API (Instagram API with Instagram Login) ──
# Приложение Meta "POWERELIX Automation" → продукт Instagram
IG_APP_ID=
IG_APP_SECRET=
IG_USER_ID=
IG_ACCESS_TOKEN=
# Дата истечения долгоживущего токена (YYYY-MM-DD), 60 дней с выпуска
IG_TOKEN_EXPIRES_AT=

# ── Apify (скрапинг конкурентов) ──
APIFY_TOKEN=

# ── Claude (Anthropic) ──
# Ключ с console.anthropic.com ИЛИ ключ ProxyAPI
ANTHROPIC_API_KEY=
# Раскомментируй и укажи, если ходишь через ProxyAPI:
# ANTHROPIC_BASE_URL=https://api.proxyapi.ru/anthropic
# Модель: claude-opus-4-8 (качество) | claude-haiku-4-5 (экономия)
CLAUDE_MODEL=claude-opus-4-8
